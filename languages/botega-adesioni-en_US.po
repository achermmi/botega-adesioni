# ── Email – default body texts ───────────────────────────────────────────────

msgid ""
"Gentile {{nome}},\n"
"\n"
"abbiamo ricevuto la sua domanda di adesione alla Cooperativa \"La Botega da "
"la Lavizzara\" come {{tipo_socio}}.\n"
"\n"
"In allegato trova il cedolino di pagamento con tutti i dati necessari per "
"effettuare il versamento.\n"
"\n"
"⚠️ La sua adesione sarà attiva solo dopo la ricezione del pagamento della "
"quota sociale di {{importo}}.\n"
"\n"
"ID Membro: {{id_membro}}\n"
"ID Quota: {{id_quota}}\n"
"\n"
"Per qualsiasi informazione non esiti a contattarci.\n"
"\n"
"Cordiali saluti,\n"
"La segreteria de La Botega da la Lavizzara\n"
"labotegalavizzara@gmail.com"
msgstr ""
"Dear {{nome}},\n"
"\n"
"we have received your membership application to the Cooperative \"La Botega "
"da la Lavizzara\" as {{tipo_socio}}.\n"
"\n"
"Please find attached the payment slip with all the details needed to "
"complete the payment.\n"
"\n"
"⚠️ Your membership will be active only after receipt of the membership "
"fee of {{importo}}.\n"
"\n"
"Member ID: {{id_membro}}\n"
"Quota ID: {{id_quota}}\n"
"\n"
"Please do not hesitate to contact us for any information.\n"
"\n"
"Kind regards,\n"
"The secretariat of La Botega da la Lavizzara\n"
"labotegalavizzara@gmail.com"

msgid ""
"Gentile {{nome}},\n"
"\n"
"Confermiamo la ricezione del pagamento per la sua adesione alla Cooperativa.\n"
"\n"
"ID Membro: {{id_membro}}\n"
"ID Quota: {{id_quota}}\n"
"Importo: {{importo}}\n"
"Data: {{data_adesione}}\n"
"\n"
"In allegato trova la conferma di pagamento e gli attestati.\n"
"\n"
"Grazie per il suo sostegno!\n"
"La Botega da la Lavizzara"
msgstr ""
"Dear {{nome}},\n"
"\n"
"We confirm receipt of your payment for membership in the Cooperative.\n"
"\n"
"Member ID: {{id_membro}}\n"
"Quota ID: {{id_quota}}\n"
"Amount: {{importo}}\n"
"Date: {{data_adesione}}\n"
"\n"
"Please find attached the payment confirmation and certificates.\n"
"\n"
"Thank you for your support!\n"
"La Botega da la Lavizzara"

msgid ""
"Gentile {{nome}},\n"
"\n"
"siamo lieti di comunicarle che è stata designata/o come Socio Onorario della "
"Cooperativa \"La Botega da la Lavizzara\".\n"
"\n"
"In allegato trova il suo attestato di Socio Onorario.\n"
"\n"
"Con stima e cordiali saluti,\n"
"Il Comitato de La Botega da la Lavizzara"
msgstr ""
"Dear {{nome}},\n"
"\n"
"we are pleased to inform you that you have been appointed as Honorary Member "
"of the Cooperative \"La Botega da la Lavizzara\".\n"
"\n"
"Please find attached your Honorary Member certificate.\n"
"\n"
"With respect and kind regards,\n"
"The Committee of La Botega da la Lavizzara"

msgid ""
"Gentile {{nome}},\n"
"\n"
"la ricordiamo che risulta ancora in sospeso il pagamento della sua quota di "
"adesione di {{importo}}.\n"
"\n"
"IBAN: {{iban}}\n"
"Riferimento: {{id_quota}}\n"
"\n"
"Cordiali saluti,\n"
"La Botega da la Lavizzara\n"
"labotegalavizzara@gmail.com"
msgstr ""
"Dear {{nome}},\n"
"\n"
"we remind you that the payment of your membership fee of {{importo}} is "
"still pending.\n"
"\n"
"IBAN: {{iban}}\n"
"Reference: {{id_quota}}\n"
"\n"
"Kind regards,\n"
"La Botega da la Lavizzara\n"
"labotegalavizzara@gmail.com"

